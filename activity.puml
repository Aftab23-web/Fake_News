@startuml FakeNews_UseCase_Documentation

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor LightYellow
  BorderColor Navy
}

title Fake News Detection System - Use Case Diagram

actor "User" as User
actor "ML Engineer" as ML
actor "Admin" as Admin

rectangle "Fake News Detection System" {
  
  ' User Use Cases
  usecase "Enter News Article" as UC1
  usecase "View Prediction" as UC2
  usecase "Check Confidence" as UC3
  
  ' ML Engineer Use Cases
  usecase "Train Model" as UC4
  usecase "Evaluate Model" as UC5
  
  ' Admin Use Cases
  usecase "Monitor System" as UC6
  usecase "Update Model" as UC7
  
  ' System Use Cases
  usecase "Preprocess Text" as UC8
  usecase "Classify Article" as UC9
  
}

' User Relationships
User --> UC1
User --> UC2
User --> UC3

' ML Engineer Relationships
ML --> UC4
ML --> UC5

' Admin Relationships
Admin --> UC6
Admin --> UC7

' Include Relationships
UC1 ..> UC8 : <<include>>
UC8 ..> UC9 : <<include>>
UC2 ..> UC9 : <<include>>

' Extend Relationships
UC3 ..> UC2 : <<extend>>

' System Relationships
UC4 ..> UC5 : <<include>>

@enduml